rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userRole() {
      return isSignedIn() && exists(userDocPath())
        ? get(userDocPath()).data.role
        : null;
    }

    function isOwner() {
      return userRole() == 'owner';
    }

    function isAssistant() {
      return userRole() == 'assistant';
    }

    function isTeamMember() {
      return isOwner() || isAssistant();
    }

    // Ingredients: owner can CRUD, assistant can read
    match /ingredients/{docId} {
      allow read: if isTeamMember();
      allow write: if isOwner();
    }

    // Recipes: owner can CRUD, assistant can read
    match /recipes/{docId} {
      allow read: if isTeamMember();
      allow write: if isOwner();
    }

    // Sales: both can read and create, only owner can update/delete
    match /sales/{docId} {
      allow read: if isTeamMember();
      allow create: if isTeamMember();
      allow update, delete: if isOwner();
    }

    // Customers: both can read and create, only owner can update/delete
    match /customers/{docId} {
      allow read: if isTeamMember();
      allow create: if isTeamMember();
      allow update, delete: if isOwner();
    }

    // Stock movements: both can read, created by system via sales
    match /stockMovements/{docId} {
      allow read: if isTeamMember();
      allow create: if isTeamMember();
    }

    // Supply expenses: owner only
    match /supplyExpenses/{docId} {
      allow read: if isTeamMember();
      allow write: if isOwner();
    }

    // Users: anyone authenticated can create their own profile, owner can manage all
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner();
    }

    // Price history: read for team, created by system on price changes
    match /priceHistory/{docId} {
      allow read: if isTeamMember();
      allow create: if isTeamMember();
    }

    // Fixed costs: owner only
    match /fixedCosts/{docId} {
      allow read: if isTeamMember();
      allow write: if isOwner();
    }
  }
}
